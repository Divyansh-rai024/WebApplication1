@{
    ViewData["Title"] = "Home | Divyansh Rai - .NET Developer Portfolio";
    ViewData["Description"] = "Portfolio of Divyansh Rai, an aspiring .NET developer skilled in ASP.NET Core, C#, and web development.";
    ViewData["Keywords"] = "Divyansh Rai, .NET Developer, ASP.NET Core, C#, Web Developer, Portfolio";
}

@section Head {
    <!-- Basic SEO -->
    <meta name="description" content="@ViewData["Description"]" />
    <meta name="keywords" content="@ViewData["Keywords"]" />
    <meta name="author" content="Divyansh Rai" />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph (for social sharing) -->
    <meta property="og:title" content="@ViewData["Title"]" />
    <meta property="og:description" content="@ViewData["Description"]" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://yourwebsite.com/" />

    <!-- Responsive -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
}

<!-- Main Content -->
<div class="text-center">
    <h1 class="display-4">Welcome to My Portfolio</h1>
    
    <p>
        I am a passionate <strong>.NET Developer</strong> specializing in 
        <strong>ASP.NET Core</strong>, building scalable and modern web applications.
    </p>

    <p>
        Learn more about building web apps with 
        <a href="https://learn.microsoft.com/aspnet/core" target="_blank">
            ASP.NET Core
        </a>.
    </p>

    <hr />

    <h2>What I Do</h2>
    <p>
        I develop secure, high-performance backend systems and responsive web applications 
        using modern technologies.
    </p>

    <h2>Skills</h2>
    <p>
        C# • ASP.NET Core • SQL Server • HTML • CSS • JavaScript
    </p>
</div>
