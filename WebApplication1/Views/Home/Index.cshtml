@{
    ViewData["Title"] = "Home Page";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>

    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background-color: #f4f6f8;
        }

        .container {
            text-align: center;
            padding: 60px;
        }

        h1 {
            color: #0077cc;
            font-size: 40px;
        }

        p {
            color: #333;
            font-size: 18px;
            max-width: 600px;
            margin: 10px auto;
        }

        .box {
            background: white;
            padding: 30px;
            border-radius: 10px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
            display: inline-block;
        }

        a {
            color: #0077cc;
            text-decoration: none;
        }

        a:hover {
            text-decoration: underline;
        }
    </style>
</head>

<body>

    <div class="container">
        <div class="box">
            <h1>Welcome 👋</h1>

            <p>
                This is a simple ASP.NET Core page with clean design and no dependencies.
            </p>

            <p>
                You can build modern web applications using 
                <a href="https://learn.microsoft.com/aspnet/core" target="_blank">
                    ASP.NET Core
                </a>.
            </p>

            <p>
                Start simple. Improve step by step 🚀
            </p>
        </div>
    </div>

</body>
</html>
